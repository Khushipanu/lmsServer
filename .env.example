# Server
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lms

# JWT & Auth
JWT_SECRET_KEY=change_me_to_a_long_random_string
ACTIVATION_SECRET=change_me_to_a_long_random_string
FORGOT_SECRET_KEY=change_me_to_a_long_random_string

# Razorpay (test keys from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# For production, GOOGLE_CALLBACK_URL must exactly match the Authorized redirect URI in Google Cloud Console.
# Example: https://learningmanagementserver.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Frontend URL (used for CORS and email links)
# Example for production: https://learningsytemclient.netlify.app
CLIENT_URL=http://localhost:5173

# Email (Brevo HTTP API - https://app.brevo.com)
# Gmail SMTP is silently blocked on Render (connections hang forever),
# so this project sends transactional email via Brevo's HTTPS API.
# 1. Sign up free at brevo.com and verify a single sender email
#    (Senders, Domains & Dedicated IPs -> Senders -> Add a Sender).
# 2. Generate an API key (profile icon -> SMTP & API -> API Keys tab).
# 3. EMAIL_FROM must exactly match the sender email you verified.
# Must also be set in Render's dashboard env vars (not read from this file).
BREVO_API_KEY=xkeysib_your_api_key
EMAIL_FROM=your_verified_sender@example.com

# AI
GEMINI_API_KEY=your_gemini_api_key
