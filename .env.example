# Server
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lms

# JWT & Auth
JWT_SECRET_KEY=change_me_to_a_long_random_string
ACTIVATION_SECRET=change_me_to_a_long_random_string
FORGOT_SECRET_KEY=change_me_to_a_long_random_string

# Razorpay (test keys from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# For production, GOOGLE_CALLBACK_URL must exactly match the Authorized redirect URI in Google Cloud Console.
# Example: https://learningmanagementserver.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Frontend URL (used for CORS and email links)
# Example for production: https://learningsytemclient.netlify.app
CLIENT_URL=http://localhost:5173

# Email (Resend HTTP API - https://resend.com/api-keys)
# Used for signup OTP + forgot-password emails. Works reliably on hosts
# like Render that block outgoing SMTP ports (Gmail SMTP does not).
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=onboarding@resend.dev

# AI
GEMINI_API_KEY=your_gemini_api_key
